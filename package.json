{
  "name": "nice-configuration",
  "version": "1.1.0",
  "type": "module",
  "description": "Shared build configuration for the nice-* ecosystem",
  "main": "src/index.js",
  "bin": {
    "nice-generate-exports": "./dist/exports/cli.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./rollup": "./src/rollup/index.js",
    "./typescript/base": "./src/typescript/base.json",
    "./typescript/react": "./src/typescript/react.json",
    "./jest/react": "./src/jest/react.js",
    "./jest/css-mock": "./src/jest/css-mock.js",
    "./exports": "./dist/exports/index.js",
    "./exports/schema.json": "./src/exports/schema.json"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.exports.json",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "nice",
    "configuration",
    "rollup",
    "typescript",
    "jest"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niceprototypes/nice-configuration.git"
  },
  "bugs": {
    "url": "https://github.com/niceprototypes/nice-configuration/issues"
  },
  "homepage": "https://github.com/niceprototypes/nice-configuration#readme",
  "dependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4"
  },
  "peerDependencies": {
    "@testing-library/jest-dom": ">=6.0.0",
    "jest": ">=29.0.0",
    "jest-environment-jsdom": ">=29.0.0",
    "rollup": ">=4.0.0",
    "ts-jest": ">=29.0.0",
    "tslib": ">=2.6.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@testing-library/jest-dom": {
      "optional": true
    },
    "jest": {
      "optional": true
    },
    "jest-environment-jsdom": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "ts-jest": {
      "optional": true
    },
    "tslib": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
