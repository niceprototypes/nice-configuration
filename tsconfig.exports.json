{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist/exports",
    "rootDir": "src/exports",
    "skipLibCheck": true
  },
  "include": ["src/exports/**/*.ts"]
}